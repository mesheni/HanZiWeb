DATABASE_URL="postgresql://hanzi:hanzi_dev@localhost:5432/hanzi"
REDIS_URL="redis://localhost:6379"
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
PORT=3001
CORS_ORIGIN="http://localhost:5173"
# Публичный origin web-клиента (для редиректа после OAuth). Необязателен.
# По умолчанию используется CORS_ORIGIN.
# WEB_PUBLIC_URL="http://localhost:5173"

# --- Push Notifications (Web Push / VAPID) ---
# Генерируйте через: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@hanzi.app"

# --- OAuth (PLAN_Features_v0.2 §13) ---
# Google OAuth 2.0 — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3001/api/auth/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
# Apple Sign In — https://developer.apple.com/account/resources/identifiers/list/serviceId
# Client secret — это JWT, подписанный вашим Apple private key (см. README).
APPLE_OAUTH_CLIENT_ID=""
APPLE_OAUTH_CLIENT_SECRET=""
# Yandex OAuth — https://oauth.yandex.ru/client/new
# Redirect URI: http://localhost:3001/api/auth/oauth/yandex/callback
YANDEX_OAUTH_CLIENT_ID=""
YANDEX_OAUTH_CLIENT_SECRET=""

# --- Email (PLAN_Features_v0.3 §2: password reset) ---
# SMTP-транспорт для писем «сбрось пароль». Если SMTP_HOST не задан,
# /api/auth/forgot-password вернёт 503 EMAIL_NOT_CONFIGURED.
# Для локальной разработки удобно использовать MailHog/MailPit:
# SMTP_HOST="localhost" SMTP_PORT=1025 SMTP_FROM="HanZi <noreply@hanzi.local>"
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
# true для 465 (TLS), false для 587 (STARTTLS, дефолт)
SMTP_SECURE="false"
# Адрес отправителя; должен быть разрешён на SMTP-сервере
SMTP_FROM="HanZi <no-reply@hanzi.app>"

# --- Email domain restriction (PLAN_Features_v0.3 §3) ---
# Список TLD (через запятую), с которыми разрешена регистрация.
# Регистрация с email в ином домене вернёт 400 EMAIL_DOMAIN_NOT_ALLOWED.
# Требование 152-ФЗ: ПД российских пользователей должны храниться
# на территории РФ, поэтому по умолчанию принимаем только .ru.
# Пример расширения: ALLOWED_EMAIL_TLDS="ru,su"
ALLOWED_EMAIL_TLDS="ru"
