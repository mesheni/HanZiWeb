generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(uuid())
  email                 String    @unique
  passwordHash          String
  xp                    Int       @default(0)
  currentStreak         Int       @default(0)
  tokenVersion          Int       @default(0)
  lastActiveDate        DateTime?
  notificationEnabled   Boolean   @default(false)
  notificationTime      String    @default("morning")
  notificationFrequency Int       @default(1)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  progress      UserWordProgress[]
  sessions      Session[]
  devices       UserDevice[]
  clozeProgress ClozeProgress[]
  decks         Deck[]

  /// Индекс для быстрого leaderboard (топ по XP за всё время).
  @@index([xp(sort: Desc)])
}

model UserDevice {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fcmToken  String   @unique
  p256dh    String   @default("")
  auth      String   @default("")
  platform  String   @default("web")
  createdAt DateTime @default(now())

  @@index([userId])
}

model Word {
  id          String   @id @default(uuid())
  character   String
  pinyin      String
  translation String
  hskLevel    Int?
  audioUrl    String?
  mnemonic    String?
  createdAt   DateTime @default(now())

  examples      Example[]
  deckWords     DeckWord[]
  progress      UserWordProgress[]
  answers       SessionAnswer[]
  clozeProgress ClozeProgress[]
}

model Example {
  id        String   @id @default(uuid())
  wordId    String
  word      Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
  chinese   String
  russian   String
  /// Откуда взят пример: tatoeba | manual | seed
  source    String   @default("manual")
  /// Tatoeba sentence id (для дедупликации и обратной ссылки)
  tatoebaId BigInt?  @unique
  createdAt DateTime @default(now())

  @@index([wordId])
}

model Deck {
  id           String   @id @default(uuid())
  name         String
  description  String?
  isSystemDeck Boolean  @default(false)
  /// Владелец кастомной колоды (null для системных).
  ownerId      String?
  owner        User?    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  /// Короткий код для шеринга (6 символов A-Z0-9). null если не расшарена.
  shareCode    String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  words    DeckWord[]
  sessions Session[]

  @@index([ownerId])
}

model DeckWord {
  deckId String
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)
  wordId String
  word   Word   @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@id([deckId, wordId])
}

enum WordState {
  new
  learning
  review
  graduated
}

model UserWordProgress {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordId         String
  word           Word      @relation(fields: [wordId], references: [id], onDelete: Cascade)
  state          WordState @default(new)
  stability      Float     @default(0)
  difficulty     Float     @default(0)
  reps           Int       @default(0)
  dueDate        DateTime  @default(now())
  lastReviewDate DateTime?

  @@unique([userId, wordId])
}

model Session {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deckId         String?
  deck           Deck?     @relation(fields: [deckId], references: [id])
  cardsTotal     Int
  cardsCompleted Int       @default(0)
  /// Режим сессии: mixed | review | learn
  mode           String    @default("mixed")
  /// Тип практики: flip-card | multiple-choice | reverse-choice | pinyin-input | tone-recognition | syllable-constructor
  practiceType   String    @default("flip-card")
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  answers SessionAnswer[]
}

model SessionAnswer {
  id         String   @id @default(uuid())
  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  wordId     String
  word       Word     @relation(fields: [wordId], references: [id])
  rating     Int // 1=Again, 2=Hard, 3=Good, 4=Easy
  answeredAt DateTime @default(now())
}

/// Прогресс пользователя по cloze-упражнениям (подстановка пропусков в предложениях).
/// Отдельная таблица, чтобы cloze-статистика не смешивалась с обычным SRS.
model ClozeProgress {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordId       String
  word         Word      @relation(fields: [wordId], references: [id], onDelete: Cascade)
  exampleId    String
  correctCount Int       @default(0)
  wrongCount   Int       @default(0)
  lastSeenAt   DateTime?
  lastCorrect  Boolean?

  @@unique([userId, exampleId])
  @@index([userId])
}
