{
  "name": "@hanzi/mobile",
  "version": "0.1.0",
  "description": "React Native client for HanZiWeb — same API + SyncEngine as apps/web, but with WatermelonDB on-device storage and a touch-first UI.",
  "private": true,
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "build:tsc": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hanzi/mobile-sdk": "workspace:*",
    "@hanzi/shared": "workspace:*",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "11.3.2",
    "@react-navigation/bottom-tabs": "^6.6.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/native-stack": "^6.10.0",
    "@nozbe/watermelondb": "0.27.1",
    "expo": "~51.0.0",
    "expo-secure-store": "~13.0.0",
    "expo-status-bar": "~1.12.0",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.0",
    "react-native-mmkv": "2.12.2",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
