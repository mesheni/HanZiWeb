# =============================================================================
# HanZiWeb — Environment Variables
# Скопируйте этот файл в .env и заполните значениями
# =============================================================================

# --- PostgreSQL (основная база данных) ---
# Строка подключения к PostgreSQL
# Формат: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://hanzi:hanzi_dev@localhost:5432/hanzi"

# Учётные данные для docker-compose (совпадают с DATABASE_URL)
POSTGRES_USER=hanzi
POSTGRES_PASSWORD=hanzi_dev
POSTGRES_DB=hanzi

# --- Redis (кэш, сессии, rate limiting) ---
# Строка подключения к Redis
REDIS_URL="redis://localhost:6379"

# --- JWT (JSON Web Tokens) ---
# Секретный ключ для access-токенов (минимум 32 символа)
# Генерируйте через: openssl rand -hex 32
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"

# Секретный ключ для refresh-токенов (минимум 32 символа)
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"

# --- Сервер ---
# Порт, на котором запускается Fastify-сервер
PORT=3001

# --- CORS ---
# Разрешённый origin для CORS (фронтенд)
# В development: http://localhost:5173
# В production: https://your-domain.com
CORS_ORIGIN="http://localhost:5173"

# --- Node Environment ---
# development | production | test
NODE_ENV=development

# --- Audio (Google Cloud TTS) ---
# Путь к JSON-ключу Google Cloud service account.
# Оставьте пустым в dev-режиме — /audio/generate вернёт 501,
# либо используйте AUDIO_PUBLIC_BASE_URL для указания вручную загруженных файлов.
GOOGLE_APPLICATION_CREDENTIALS=
# Имя GCS-бакета для хранения сгенерированных mp3 (если не задан — локальное хранилище).
GCS_BUCKET_NAME=
# Локальная директория для аудио в dev-режиме.
AUDIO_STORAGE_PATH=./storage/audio
# Публичный base URL для доступа к локальному аудио.
AUDIO_PUBLIC_BASE_URL=http://localhost:3001/audio/files

# --- Stripe (Pro-тариф) ---
# Секретный ключ Stripe (из Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=
# Секрет вебхука Stripe (из Dashboard → Developers → Webhooks)
STRIPE_WEBHOOK_SECRET=
# Публикуемый ключ Stripe (из Dashboard → Developers → API keys)
STRIPE_PUBLISHABLE_KEY=
# URL для редиректа после успешной оплаты
STRIPE_SUCCESS_URL=http://localhost:5173/pricing?success=true
# URL для редиректа после отмены оплаты
STRIPE_CANCEL_URL=http://localhost:5173/pricing?canceled=true
